generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
  VIEWER
}

enum CodeType {
  TWO_FACTOR
  PASSWORD_RESET
}

model GithubRepo {
  id          String  @id @default(uuid())
  name        String
  url         String  @unique
  stars       Int
  language    String?
  description String? @db.Text

  statsId String
  stats   GithubStats @relation(fields: [statsId], references: [id], onDelete: Cascade)

  project Project?
  order   Int      @default(0)

  @@index([statsId])
}

model GithubStats {
  id          String @id @default(uuid())
  username    String @unique
  followers   Int
  publicRepos Int
  totalStars  Int

  repos GithubRepo[]

  updatedAt DateTime @updatedAt
}

model Project {
  id          String  @id @default(uuid())
  slug        String  @unique
  title       String
  description String  @db.Text
  content     String? @db.Text

  imageUrl String?
  demoUrl  String?

  isFeatured Boolean  @default(false)
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())

  techStack TechStack[]
  gallery   ProjectImage[]

  githubRepoId String?     @unique
  githubRepo   GithubRepo? @relation(fields: [githubRepoId], references: [id], onDelete: SetNull)

  @@index([isVisible, createdAt])
  @@index([isFeatured])
}

model ProjectImage {
  id    String  @id @default(uuid())
  url   String
  alt   String?
  order Int     @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, order])
}

model TechStack {
  id       String  @id @default(uuid())
  name     String  @unique
  icon     String?
  category String
  color    String?

  projects Project[]

  @@index([category])
}

model Experience {
  id          String    @id @default(uuid())
  position    String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String    @db.Text
  isCurrent   Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([startDate(sort: Desc)])
}

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  username         String  @unique
  passwordDigest   String
  twoFactorEnabled Boolean @default(false)

  name      String?
  headline  String?
  bio       String? @db.Text
  avatarUrl String?

  socials Json? @default("{}")

  role Role @default(USER)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  VerificationCode VerificationCode[]

  @@index([email])
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  type      CodeType
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, type])
}
