generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum TechStackCategory {
  Frontend
  Backend
  Fullstack
  Mobile
  Infrastructure
  Database
  Design
  Tools
}

enum PermissionFlag {
  READ
  WRITE
  ADMIN
}

enum Role {
  USER
  ADMIN
  MODERATOR
  VIEWER
}

enum CodeType {
  TWO_FACTOR
  PASSWORD_RESET
}

enum ReactionType {
  LIKE
  LOVE
  HAHA
  WOW
  SAD
  ANGRY
}

model GithubRepo {
  id          String  @id @default(uuid())
  name        String
  url         String  @unique
  stars       Int
  language    String?
  description String? @db.Text

  statsId String
  stats   GithubStats @relation(fields: [statsId], references: [id], onDelete: Cascade)

  project Project?
  order   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commits     GithubCommit[]

  @@index([statsId])
}

model GithubStats {
  id          String @id @default(uuid())
  username    String @unique
  followers   Int
  publicRepos Int
  totalStars  Int

  repos GithubRepo[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Project {
  id          String  @id @default(uuid())
  slug        String  @unique
  title       String
  description String  @db.Text
  content     String? @db.Text

  imageUrl String?
  demoUrl  String?

  isFeatured Boolean  @default(false)
  isVisible  Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  techStack TechStack[]
  gallery   ProjectImage[]

  githubRepoId String?     @unique
  githubRepo   GithubRepo? @relation(fields: [githubRepoId], references: [id], onDelete: SetNull)

  @@index([isVisible, createdAt])
  @@index([isFeatured])
}

model ProjectImage {
  id    String  @id @default(uuid())
  url   String
  alt   String?
  order Int     @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([projectId, order])
}

model TechStack {
  id       String  @id @default(uuid())
  name     String  @unique
  icon     String?
  category TechStackCategory
  color    String?

  projects Project[]

  createdAt  DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([category])
}

model Experience {
  id          String    @id @default(uuid())
  position    String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String    @db.Text
  notes       String?   @db.Text
  isCurrent   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([startDate(sort: Desc)])
}

model User {
  id               String  @id @default(uuid())
  email            String  @unique
  username         String  @unique
  passwordDigest   String
  twoFactorEnabled Boolean @default(false)

  name      String?
  headline  String?
  bio       String? @db.Text
  avatarUrl String?

  socials Json? @default("{}")
  permissions       UserPermission[]

  role Role @default(USER)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt

  VerificationCode VerificationCode[]
  posts Post[]
  comments Comment[]
  reactions Reaction[]

  @@index([email])
}

model UserPermission {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  resource  String
  flags     PermissionFlag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, resource])
  @@index([userId])
}

model VerificationCode {
  id        String   @id @default(uuid())
  code      String
  type      CodeType
  expiresAt DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([userId, type])
}

model GithubCommit {
  id        String   @id @default(uuid())
  sha       String   @unique
  message   String   @db.Text
  description   String?   @db.Text
  url       String
  date      DateTime
  isFeatured Boolean  @default(true)

  repoId    String
  repo      GithubRepo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt        DateTime    @default(now())       @updatedAt

  @@index([repoId, date(sort: Desc)])
}

model Post {
  id        String   @id @default(uuid())
  title       String
  subtitle    String?   @db.Text
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String    @db.Text
  footer      String?   @db.Text
  coverImageUrl  String?

  visibility Role @default(USER)


  viewCount   Int       @default(0)

  userId    String
  author      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  tags Tag[]
  reactions Reaction[]
  comments Comment[]

  publishedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt        DateTime    @default(now())       @updatedAt

  @@index([userId])
  @@index([slug])
  @@index([createdAt(sort: Desc)])
  @@index([visibility, publishedAt])
  @@index([deletedAt])
}

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  color       String?

  posts       Post[]

  categoryId String?
  category   TagCategory? @relation(fields: [categoryId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
}

model TagCategory {
  id    String @id @default(uuid())
  name  String @unique

  tags  Tag[]

  parentId String?

  parent TagCategory? @relation("categories", fields: [parentId], references: [id])
  categories TagCategory[] @relation("categories")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
}

model Comment {
  id        String   @id @default(uuid())
  visibility Role @default(USER)

  userId    String
  author      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  content String @db.Text
  isReply Boolean

  parentId String?

  parent Comment? @relation("replies", fields: [parentId], references: [id])
  replies Comment[] @relation("replies")

  postId String
  post Post @relation(fields: [postId], references: [id])

  reactions Reaction[]

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt        DateTime    @default(now())       @updatedAt

  @@index([postId])
  @@index([parentId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Reaction {
  id        String   @id @default(uuid())

  type ReactionType
  postId    String?
  post      Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId    String
  author      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  commentId String
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt        DateTime    @default(now())       @updatedAt

  @@index([commentId])
  @@index([postId])
  @@index([userId])
}
