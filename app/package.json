{
  "name": "@portfolio/app",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./trpc": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/contract.ts --format esm --dts",
    "start": "node --enable-source-maps dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:studio": "prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "prisma": {
    "seed": "npx tsx ./src/scripts/seeder/main.ts"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@portfolio/shared": "*",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@react-email/components": "^1.0.8",
    "@scalar/express-api-reference": "^0.9.4",
    "@trpc/server": "^11.8.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "argon2": "^0.44.0",
    "bullmq": "^5.67.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.1",
    "octokit": "^5.0.5",
    "pg": "^8.16.3",
    "pino": "^10.2.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^10.0.1",
    "redis": "^5.10.0",
    "superjson": "^2.2.6",
    "trpc-to-openapi": "^3.2.0",
    "yarn": "^1.22.22",
    "zod": "^4.0.0",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.2.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.3.0"
  }
}
